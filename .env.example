# Supabase Configuration
# The JS client uses PostgREST (HTTP REST API), not direct PostgreSQL connections.
# Scaling is handled by caching (lib/cache.ts) + Supabase Pro plan rate limits.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Application Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional direct Postgres URL for launch-security validation.
# Required for: npm run security:supabase
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ca-central-1.pooler.supabase.com:6543/postgres

# Optional disposable database URL for restore drills.
# Required for: RESTORE_DRILL_CONFIRM=restore-non-production BACKUP_FILE=... npm run db:restore-drill
RESTORE_DRILL_DB_URL=postgresql://localhost:5432/wolfwhale_restore_drill

# Enterprise identity and SIS integration readiness.
# Set SSO_PROVIDER_TYPE to none, oidc, or saml.
SSO_PROVIDER_TYPE=none
OIDC_ISSUER=https://identity.example.edu
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_REDIRECT_URI=https://your-domain.example/auth/confirm
SAML_METADATA_URL=https://identity.example.edu/saml/metadata
SAML_ENTITY_ID=https://your-domain.example
SAML_ACS_URL=https://your-domain.example/auth/saml/callback
ONEROSTER_IMPORT_MODE=csv
ONEROSTER_SFTP_HOST=sftp.example.edu
ONEROSTER_SFTP_USERNAME=wolfwhale
ONEROSTER_SFTP_PRIVATE_KEY_PATH=/secure/path/oneroster.key

# Enterprise support and incident contacts.
SUPPORT_ESCALATION_EMAIL=support@example.edu
INCIDENT_COMMANDER_EMAIL=incident@example.edu
PRIVACY_OFFICER_EMAIL=privacy@example.edu

# Upstash Redis Configuration (rate limiting)
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token-here

# Sentry Configuration
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
SENTRY_ORG=your-sentry-org-here
SENTRY_PROJECT=your-sentry-project-here

# Vercel Cron
# Vercel sends Authorization: Bearer $CRON_SECRET to configured cron routes.
CRON_SECRET=replace-with-a-long-random-secret

# Demo Accounts (set a strong password — used by all 4 demo role accounts)
DEMO_ACCOUNT_PASSWORD=your-demo-password-here

# Feature Flags
NEXT_PUBLIC_ENABLE_GAMIFICATION=true
NEXT_PUBLIC_ENABLE_SOUNDS=true
NEXT_PUBLIC_ENABLE_MUSIC=true
