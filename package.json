  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:migrate": "supabase migration up",
    "db:seed": "supabase db reset",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > types/database.types.ts",
    "db:test-accounts": "bash scripts/seed-test-accounts.sh",
