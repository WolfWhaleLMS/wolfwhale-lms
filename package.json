    "enterprise:check": "npx tsx scripts/check-enterprise-readiness.ts",
    "district:proof": "npx tsx scripts/check-district-proof.ts",
    "district:verify": "npm test tests/lms-district-scale.test.ts && npm run enterprise:check && npm run district:proof && npm run load:smoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:ci": "next build",
    "security:supabase": "npx tsx scripts/check-supabase-launch-security.ts",
